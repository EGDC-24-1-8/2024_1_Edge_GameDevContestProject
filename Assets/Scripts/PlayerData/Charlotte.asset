  textDataStart:
  - "\uB3C8 \uBC8C \uC2DC\uAC04\uC774\uC57C."
  - "\uC774\uACA8\uBCF4\uACA0\uC5B4."
  textDataRecieveCard:
  - "\uC5B4\uB5A4 \uCE74\uB4DC\uB4E0 \uC0C1\uAD00\uC5C6\uC5B4."
  - "\uB0B4 \uC190\uC5D0\uB294 \uD56D\uC0C1 \uC88B\uC740 \uCE74\uB4DC\uB9CC \uB4E4\uC5B4\uC624\uC9C0."
  textDataCall:
  - "\uD6C4\uD6C4, \uD750\uB984\uC774 \uC88B\uB124."
  - "\uC774\uB300\uB85C \uAC00\uBA74 \uC88B\uACA0\uB294\uB370."
  textDataRaise:
  - "\uC880 \uB354 \uC62C\uB824\uB3C4 \uAD1C\uCC2E\uACA0\uB124."
  - "\uBD99\uC5B4\uBCF4\uACA0\uC5B4?"
  textDataFold:
  - "\uC774\uB7EC\uBA74 \uCC28\uC9C8\uC774 \uC0DD\uAE30\uB294\uB370..."
  - "\uC820\uC7A5..."
  textDataTime:
  - "\uBE68\uB9AC \uC9C4\uD589\uD574\uC92C\uC73C\uBA74 \uD558\uB294\uB370."
  - "\uC2DC\uAC04\uC774 \uB0AD\uBE44\uB418\uACE0 \uC788\uC5B4."
  textDataWin:
  - "\uC774 \uB3C8\uC740 \uB0B4\uAC00 \uAC00\uC838\uAC08\uAC8C."
  - "\uB2E4\uC74C \uD310\uB3C4 \uC774\uB807\uAC8C \uB418\uBA74 \uC88B\uACA0\uB294\uB370."
  - "\uC774\uBC88 \uD310\uC740 \uB0B4\uAC00 \uC6B4\uC774 \uC88B\uC558\uB124."
  textDataDetected:
  - "\uC774\uAC78 \uB4E4\uD0A4\uB2E4\uB2C8..."
  textDataMissDetected:
  - "\uC6C3\uAE30\uC2DC\uB124, \uB0B4\uAC00 \uC18D\uC600\uB2E4\uACE0?"
  textDataBusted:
  - "\uD765, \uB2E4\uB978 \uD310\uC744 \uCC3E\uC544\uBD10\uC57C\uACA0\uC5B4."
  textDataSuspicion:
  - "\uBA48\uCDB0. \uC190\uB180\uB9BC\uC774 \uB2E4 \uBCF4\uC778\uB2E4\uACE0."
  textDataDayWin:
  - "\uC624\uB298\uC740 \uACE0\uB9C8\uC6E0\uC5B4. \uB2E4\uC74C\uC5D0 \uB610 \uBD10."
  textDataDayLose:
  - "\uAE30\uB300\uB3C4 \uC548 \uD588\uC9C0\uB9CC, \uC2E4\uB825\uC774 \uD615\uD3B8\uC5C6\uB124."
