  m_Script: {fileID: 11500000, guid: bf125c079ea812b44ae9f53a14d7e6a1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  displayImage: {fileID: 685756730}
  displayText: {fileID: 140698214}
  nextButton: {fileID: 519680939}
  images:
  - {fileID: 21300000, guid: 09eef23cf2bccc844bb2227a7d13df7a, type: 3}
  - {fileID: 21300000, guid: cf5d64a215bbb1a4e8b03c18e130b967, type: 3}
  - {fileID: 21300000, guid: 68050d0d7894d7d48a5b42f2c56248a2, type: 3}
  - {fileID: 21300000, guid: 2d8806908e41f8a489e61eabf2865f94, type: 3}
  - {fileID: 21300000, guid: 2003a3ac13fad5248a6a8b55f63b1f9c, type: 3}
  - {fileID: 21300000, guid: 5c7a496f163fcfc458477542e2b544ea, type: 3}
  - {fileID: 21300000, guid: 2003a3ac13fad5248a6a8b55f63b1f9c, type: 3}
  - {fileID: 21300000, guid: 2003a3ac13fad5248a6a8b55f63b1f9c, type: 3}
  - {fileID: 21300000, guid: 2003a3ac13fad5248a6a8b55f63b1f9c, type: 3}
  - {fileID: 21300000, guid: 2003a3ac13fad5248a6a8b55f63b1f9c, type: 3}
  - {fileID: 21300000, guid: 2003a3ac13fad5248a6a8b55f63b1f9c, type: 3}
  - {fileID: 21300000, guid: 2003a3ac13fad5248a6a8b55f63b1f9c, type: 3}
  - {fileID: 21300000, guid: 2003a3ac13fad5248a6a8b55f63b1f9c, type: 3}
  - {fileID: 21300000, guid: 2003a3ac13fad5248a6a8b55f63b1f9c, type: 3}
  dialogue:
  - "\uD55C \uB3C4\uBC15\uC7A5\uC73C\uB85C \uB4E4\uC5B4\uAC04 \uB2F9\uC2E0\uC740
    \uB3C4\uBC15\uC7A5\uC5D0\uC11C \uB9CE\uC740 \uB3C8\uC744 \uB530\uAE30 \uC704\uD574
    \uD14C\uC774\uBE14\uC5D0 \uC549\uC544 \uCE74\uB4DC \uAC8C\uC784\uC744 \uD558\uC600\uB2E4.
    \n\uCD08\uBC18\uC5D0\uB294 \uAC01\uC885 \uC0AC\uAE30 \uAE30\uC220\uB85C \uAC8C\uC784\uC744
    \uC774\uACA8 \uB3C8\uC774 \uC798 \uB4E4\uC5B4\uC624\uB294 \uB4EF \uD588\uB2E4.\r"
  - "\uD558\uC9C0\uB9CC \uAC8C\uC784\uC744 \uC9C4\uD589\uD560\uC218\uB85D \uB2F9\uC2E0\uC774
    \uC0AC\uAE30\uCE58\uB294 \uAC83\uC744 \uB208\uCE58\uCC48 \uB51C\uB7EC\uC758 \uACE0\uBC1C\uB85C
    \n\uB2F9\uC2E0\uC758 \uB3C8\uC740 \uBB3C\uB860 \uCC98\uC74C\uC5D0 \uC18C\uC9C0\uD588\uB358
    \uB3C8\uAE4C\uC9C0 \uC804\uBD80 \uC783\uAC8C \uB418\uC5C8\uACE0, \n\uC774\uC73D\uACE0
    \uB3C4\uBC15\uC7A5\uC5D0\uC11C \uCAD3\uACA8\uB098\uAC8C \uB418\uC5C8\uB2E4.\r"
  - "\uB3C4\uBC15\uC7A5\uC5D0\uC11C \uCAD3\uACA8\uB098\uACE0 \uBE5A\uC744 \uC9C0\uAC8C
    \uB418\uC5B4\uBC84\uB9B0 \uB2F9\uC2E0\uC758 \uC55E\uC5D0 \uAC80\uC740 \uBCF5\uC7A5\uC758
    \uC0AC\uB78C\uB4E4\uC774 \uCC3E\uC544\uC654\uB2E4. \n\uC774\uB4E4\uC740 \uB2F9\uC2E0\uC758
    \uC0AC\uAE30 \uAE30\uC220\uC5D0 \uB208\uC744 \uB4E4\uC5EC \uCD1D\uC744 \uAEBC\uB0B4\uB4E0
    \uCC44 \uB2F9\uC2E0\uC5D0\uAC8C \uC81C\uC548\uC744 \uD558\uC600\uB2E4.\r"
  - "\uB3C8\uB3C4 \uC783\uACE0 \uB0A8\uC740 \uBAA9\uC228\uB3C4 \uC800\uB4E4\uC758
    \uC190\uC5D0 \uC788\uAE30\uC5D0 \n\uB2F9\uC2E0\uC740 \uADF8\uB4E4\uC758 \uC81C\uC548\uC744
    \uBC1B\uC544\uB4E4\uC774\uACE0 \n\uB3C4\uBC15\uC7A5\uC5D0\uC11C \uC5BB\uC740
    \uBE5A\uC744 \uAC1A\uC544\uB098\uAC00\uAE30 \uC2DC\uC791\uD55C\uB2E4.\r"
  - "\uB9C8\uD53C\uC544: \uC5EC\uAE30\uC5D0 \uB2E4\uC2DC \uC628 \uAC78 \uD658\uC601\uD574.
    \n\uC9C0\uAE08 \uB124\uAC00 \uD50C\uB808\uC774\uC5B4\uAC00 \uC544\uB2CC \uB51C\uB7EC\uAC00
    \uB41C \uAC83 \uBE7C\uACE0\uB294. \n\uAC8C\uC784\uC744 \uC2DC\uC791\uD558\uAE30
    \uC804\uC5D0 \uB0B4\uAC00 \uAC04\uB2E8\uD788 \uC124\uBA85\uD574\uC8FC\uB3C4\uB85D
    \uD558\uC9C0\r"
  - "\uB9C8\uD53C\uC544: \uBCF8 \uAC8C\uC784\uC740 \uBE14\uB799\uC7AD\uC73C\uB85C
    \uC9C4\uD589\uD560 \uAC70\uC57C. \n\uD639\uC2DC\uB098 \uD574\uC11C \uB2E4\uC2DC
    \uB9D0\uD558\uB294\uB370 \uCE74\uB4DC\uAC12\uC774 21\uC5D0 \n\uADFC\uC811\uD574\uC57C
    \uD558\uACE0 21\uB97C \uCD08\uACFC\uD558\uBA74 \uC9C0\uB294 \uAC8C\uC784\uC774\uC57C\r"
  - "\uB9C8\uD53C\uC544: \uD558\uC9C0\uB9CC \uC6B0\uB9AC \uB3C4\uBC15\uC7A5\uC5D0
    \u2018\uADC0\uC911\uD55C \uC190\uB2D8\u2019\uC774 \uB4E4\uC5B4\uC624\uC2DC\uAC70\uB4E0.
    \n\uADF8 \uC190\uB2D8\uC744 \u2018\uC544\uAD70\u2019\uC73C\uB85C \uCE6D\uD558\uB294
    \uAC78\uB85C \uD558\uBA74 \uB10C \uC544\uAD70\uC744 \uC774\uAE30\uB3C4\uB85D
    \uAC8C\uC784\uC744 \uC2AC\uCA4D \uC870\uC791\uD558\uBA74 \uB3FC. \n\uBC11\uC7A5\uC744
    \uBE7C\uB4E0\uC9C0 \uCE74\uB4DC\uB97C \uC911\uAC04\uC5D0\uC11C \uBE7C\uC624\uB4E0\uC9C0
    \uC0C1\uAD00\uC5C6\uC9C0\uB9CC \uB2E4\uB978 \uD50C\uB808\uC774\uC5B4\uB4E4\uC758
    \uC758\uC2EC\uC744 \uB108\uBB34 \uC0AC\uBA74 \uC548 \uB3FC\r"
  - "\uB9C8\uD53C\uC544: \uC544\uAD70\uC758 \uC2B9\uB9AC\uB97C \uC774\uB04C\uAE30
    \uC704\uD574\uC120 \uB51C\uB7EC\uC778 \uB124\uAC00 \uC2E0\uD638\uB97C \uC904
    \uD544\uC694\uAC00 \uC788\uACA0\uC9C0? \n\uC544\uAD70\uC5D0\uAC8C \uBCF4\uB0B4\uB294
    \uC2E0\uD638 \uBA85\uCE6D\uC744 \u2018E\u2019\uB77C\uACE0 \uD560 \uAC70\uC57C.
    \n\uC774 \uC2E0\uD638\uB294 \uC544\uAD70\uC5D0\uAC8C \uB808\uC774\uC988\uB97C
    \uD574\uB77C, \uD3F4\uB4DC\uD574\uB77C \uB4F1\uC758 \uD589\uB3D9\uC744 \uB0B4\uB9B4
    \uC218 \uC788\uB294 \uAC70\uC9C0. \n\uBCF4\uD1B5\uC758 \uD50C\uB808\uC774\uC5B4\uB294
    \uC54C\uC544\uCC44\uC9C0 \uBABB\uD560 \uAC70\uC57C\r"
  - "\uB9C8\uD53C\uC544: \uC544, \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uC6B0\uB9AC \uC190\uB2D8\uC758
    \uC9C0\uAC11\uC744 \uC77C\uC815\uB7C9\uAE4C\uC9C0 \uCC44\uC6CC\uB4DC\uB824\uC57C
    \uD558\uB294 \uAC70 \uC54C\uC9C0? \n\uAC8C\uC784\uC774 \uC804\uBD80 \uB05D\uB0A0
    \uB54C\uAE4C\uC9C0 \uC77C\uC815\uB7C9\uC744 \uCC44\uC6B0\uC9C0 \uBABB\uD55C\uB2E4\uBA74
    \uC6B0\uB9AC\uB294 \uB110 \uCC98\uBD84\uD560 \uAC70\uC57C. \n\uADF8\uB7EC\uB2C8
    \uC6B0\uB9AC \uC190\uB2D8\uC744 \uC704\uD574 \uB2E4\uB978 \uD50C\uB808\uC774\uC5B4\uC758
    \uB208\uC744 \uD53C\uD558\uBA70 \uAC8C\uC784\uC744 \uC798 \uB9C8\uCCD0\uBD10.
    \n\uACE7 \uAC8C\uC784\uC774 \uC2DC\uC791\uD558\uB2C8 \uAC00\uBCF4\uB3C4\uB85D
    \uD558\uC9C0\r"
  - "\uB9C8\uD53C\uC544: \uBB34\uC0AC\uD788 \uD558\uB8E8\uB97C \uC798 \uB118\uACBC\uB124.
    \n\uC5ED\uC2DC \uBE5A\uB9CC \uC544\uB2C8\uC5C8\uC73C\uBA74 \uC6B0\uB9AC \uCABD\uC5D0\uC11C
    \uC9C4\uC791\uC5D0 \uACE0\uC6A9\uD588\uC744 \uC7AC\uB2A5\uC774\uC57C. \n\uBB3C\uB860
    \uC9C0\uAE08 \uADF8\uAC78 \uB530\uC9C8 \uB54C\uAC00 \uC544\uB2CC \uAC8C \uC544\uC26C\uC6B8
    \uB530\uB984\uC774\uC9C0\uB9CC\r"
  - "\uB9C8\uD53C\uC544: \uC624\uB298\uBD80\uD130\uB294 \uC870\uAE08\uC740 \uBD88\uB7C9\uD55C
    \uD50C\uB808\uC774\uC5B4\uB4E4\uC774 \uCC3E\uC544\uC62C \uAC70\uC57C. \n\uBB34\uC2A8
    \uB9D0\uC774\uB0D0\uACE0? \n\uB108 \uBAB0\uB798 \uCE74\uB4DC\uAC12\uC744 \uBC14\uAFD4\uC11C
    \uAC8C\uC784\uC758 \uD310\uB3C4\uB97C \uB4A4\uC5CE\uC73C\uB824\uB294 \uB188\uB4E4\uC774\uC9C0.
    \n\uC6B0\uB9AC \uC190\uB2D8\uC758 \uC9C0\uAC11\uC744 \uBE8F\uC73C\uB824\uB294
    \uC18C\uB9E4\uCE58\uAE30\uAC19\uC740 \uB0A0\uAC15\uB3C4\uB4E4\uC774\uB77C\uB2C8\uAE50\r"
  - "\uB9C8\uD53C\uC544: \uADF8\uB798\uC11C \uC774\uBC88\uC5D0\uB294 \uC0C8\uB85C\uC6B4
    \uC2E0\uD638\uB97C \uB108\uC5D0\uAC8C \uC54C\uB824\uC904 \uAC70\uC57C. \n\uC77C\uBA85
    \u2018\uACE0\uBC1C\u2019\uC774\uB77C\uACE0 \uBD88\uB9AC\uB294 \u2018R\u2019\uB97C
    \uC54C\uB824\uC8FC\uB3C4\uB85D \uD558\uC9C0. \n\uC0AC\uAE30\uCE58\uB294 \uD50C\uB808\uC774\uC5B4\uB97C
    \uBCF4\uACE0 \uADF8\uB188\uC744 \uACE0\uBC1C\uD558\uBA74 \uC6B0\uB9AC\uAC00 \uC9C1\uC811
    \uCC98\uB9AC\uD560 \uAC70\uC57C. \n\uADF8\uB9AC\uACE0 \uACE0\uBC1C\uC5D0 \uCC98\uB9AC\uB41C
    \uD50C\uB808\uC774\uC5B4\uB294 \uC18C\uC9C0\uAE08\uC774 \uBAB0\uC218\uB418\uACE0
    \uC774\uBC88 \uAC8C\uC784\uC5D0\uC11C \uC81C\uC678\uB3FC\r"
  - "\uB9C8\uD53C\uC544: \uC0AC\uAE30\uB97C \uCE60 \uC218\uB3C4 \uC788\uACE0 \uC815\uC9C1\uD558\uAC8C
    \uD558\uB294 \uB2E4\uC591\uD55C \uD50C\uB808\uC774\uC5B4\uAC00 \uC788\uC73C\uB2C8
    \n\uD2B9\uC815 \uD50C\uB808\uC774\uC5B4\uB97C \uBB34\uC791\uC815 \uC758\uC2EC\uD558\uC9C0
    \uB9D0\uB77C\uACE0. \n\uACE7 \uAC8C\uC784\uC774 \uC2DC\uC791\uD560 \uAC83 \uAC19\uC73C\uB2C8
    \uAC00\uBD10\uC57C\uACA0\uB124. \n\uC774\uBC88\uC5D0\uB3C4 \uC6B0\uB9AC \uC190\uB2D8\uC758
    \uC9C0\uAC11\uC744 \uBD80\uD0C1\uD55C\uB2E4\r"
  - "\uB9C8\uD53C\uC544: \uC544, \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uC6B0\uB9AC \uC190\uB2D8\uC758
    \uC9C0\uAC11\uC744 \uC77C\uC815\uB7C9\uAE4C\uC9C0 \uCC44\uC6CC\uB4DC\uB824\uC57C
    \uD558\uB294 \uAC70 \uC54C\uC9C0? \n\uAC8C\uC784\uC774 \uC804\uBD80 \uB05D\uB0A0
    \uB54C\uAE4C\uC9C0 \uC77C\uC815\uB7C9\uC744 \uCC44\uC6B0\uC9C0 \uBABB\uD55C\uB2E4\uBA74
    \uC6B0\uB9AC\uB294 \uB110 \uCC98\uBD84\uD560 \uAC70\uC57C. \n\uADF8\uB7EC\uB2C8
    \uC6B0\uB9AC \uC190\uB2D8\uC744 \uC704\uD574 \uB2E4\uB978 \uD50C\uB808\uC774\uC5B4\uC758
    \uB208\uC744 \uD53C\uD558\uBA70 \uAC8C\uC784\uC744 \uC798 \uB9C8\uCCD0\uBD10.
    \n\uACE7 \uAC8C\uC784\uC774 \uC2DC\uC791\uD558\uB2C8 \uAC00\uBCF4\uB3C4\uB85D
    \uD558\uC9C0\r"
