  - {fileID: 21300000, guid: 2003a3ac13fad5248a6a8b55f63b1f9c, type: 3}
  - {fileID: 21300000, guid: b7e3698d5f1dfae439e55193f2cef747, type: 3}
  - {fileID: 21300000, guid: b7e3698d5f1dfae439e55193f2cef747, type: 3}
  - {fileID: 21300000, guid: b7e3698d5f1dfae439e55193f2cef747, type: 3}
  - {fileID: 21300000, guid: b7e3698d5f1dfae439e55193f2cef747, type: 3}
  - {fileID: 21300000, guid: b7e3698d5f1dfae439e55193f2cef747, type: 3}
  dialogue:
  - "\uD0C0\uC9DC\uC758 \uC0B6\uC744 \uC0B4\uC544\uAC00\uB358 \uB2F9\uC2E0\uC740
    \uC5EC\uB290 \uB54C\uC640 \uAC19\uC774 \uCE74\uC9C0\uB178\uC5D0 \uB4E4\uC5B4\uC130\uB2E4.\r\n\uB298
    \uADF8\uB7AC\uB4EF\uC774, \uAC01\uC885 \uC0AC\uAE30 \uAE30\uC220\uB85C \uB3C8\uC744
    \uC4F8\uC5B4\uB2F4\uB358 \uADF8 \uB54C\u2026\r"
  - "\uB204\uAD70\uAC00 \uB2F9\uC2E0\uC758 \uC0AC\uAE30 \uD589\uAC01\uC744 \uB208\uCE58\uCC58\uACE0,\r\n\uB2F9\uC2E0\uC740
    \uBAA8\uB4E0 \uB3C8\uC744 \uBE7C\uC557\uAE34 \uCC44 \uB3C4\uB9DD\uCE58\uB4EF
    \uBE60\uC838\uB098\uC654\uB2E4.\r\r"
  - "\uADF8\uB7EC\uB098 \uC5BC\uB9C8 \uC9C0\uB098\uC9C0 \uC54A\uC544 \uB2F9\uC2E0\uC740
    \uCD1D\uC744 \uB4E0 \uAC80\uC740 \uC591\uBCF5\uC758 \uC0AC\uB0B4\uB4E4\uC5D0\uAC8C
    \uBD99\uC7A1\uD614\uACE0,\r\n\uBAA9\uC228\uC744 \uAD6C\uAC78\uD558\uB358 \uB2F9\uC2E0\uC5D0\uAC8C
    \uADF8 \uB0A8\uC790\uB4E4\uC740 \uB73B\uBC16\uC758 \uC81C\uC548\uC744 \uAC74\uB128\uB2E4.\r\r"
  - "\uC81C\uC548\uC774\uB780, \uB2F9\uC2E0\uC774 \uB3C4\uB9DD\uCE5C \uADF8 \uB3C4\uBC15\uC7A5\uC5D0\uC11C,
    \uB51C\uB7EC\uB85C \uC77C\uD558\uB77C\uB294 \uAC83.\r\n\uC81C\uC548\uC744 \uBE59\uC790\uD55C
    \uD611\uBC15\uC744 \uBC1B\uC544\uB4E4\uC778 \uB2F9\uC2E0\uC740 \uB3C4\uBC15\uC7A5\uC73C\uB85C
    \uBC1C\uAC78\uC74C\uC744 \uC62E\uAE34\uB2E4.\r"
  - "\uB9C8\uD53C\uC544: \uC774\uACF3\uC5D0 \uB2E4\uC2DC \uC628 \uAC78 \uD658\uC601\uD574.
    \uBB50, \uC5ED\uD560\uC740 \uC870\uAE08 \uBC14\uB00C\uC5C8\uC9C0\uB9CC \uB9D0\uC774\uC57C.\r\n\uAC8C\uC784\uC744
    \uC2DC\uC791\uD558\uAE30 \uC804, \uB124\uAC00 \uBB34\uC2A8 \uC77C\uC744 \uD574\uC57C
    \uD560\uC9C0 \uC124\uBA85\uD574\uC8FC\uC9C0.\r\r"
  - "\uB9C8\uD53C\uC544: \uB124\uAC00 \uC9C4\uD589\uD560 \uAC8C\uC784\uC740 \uBE14\uB799\uC7AD\uC774\uC57C.
    \uCE74\uB4DC\uC758 \uC138 \uC7A5\uC758 \uD569\uC774 21\uC5D0 \uAC00\uAE4C\uC6B0\uBA74
    \uC2B9\uB9AC\uD558\uB294 \uAC8C\uC784\uC774\uC9C0.\r\n\uB2E8, 21\uC744 \uB118\uAE30\uBA74
    \uC989\uC2DC \uD328\uBC30\uD558\uAC8C \uB3FC. \uB610, J, Q, K\uB294 10\uC73C\uB85C
    \uCDE8\uAE09\uD558\uC9C0.\r"
  - "\uB9C8\uD53C\uC544: \uADF8\uB9AC\uACE0 \uC624\uB298 \uC6B0\uB9AC \uB3C4\uBC15\uC7A5\uC5D0
    \u2018\uC911\uC694\uD55C \uC190\uB2D8\u2019\uC774 \uBC29\uBB38\uD560 \uAC70\uC57C.\r\n\uB124\uAC00
    \uD560 \uC77C\uC740, \uADF8 \uC190\uB2D8\uC774 \uC5EC\uAE30\uC11C \uB3C8\uC744
    \uB530\uC11C \uB3CC\uC544\uAC00\uAC8C \uD558\uB294 \uAC70\uC9C0.\n\uB124\uAC00
    \uD14C\uC774\uBE14\uC5D0 \uC549\uC790\uB9C8\uC790 \uCC98\uC74C\uC73C\uB85C \uB9D0\uC744
    \uAEBC\uB0B4\uB294 \uC0AC\uB78C\uC774 \uC190\uB2D8\uC774\uC57C.\r\r"
  - "\uB9C8\uD53C\uC544: \uCE74\uB4DC\uB97C \uB098\uB204\uC5B4 \uC904 \uB54C, \uB9E8
    \uC717\uC7A5, \uB9E8 \uC704\uC5D0\uC11C \uB450 \uBC88\uC9F8 \uC7A5, \uB9E8 \uC544\uB7AB\uC7A5
    \uC911\r\n\uC5B4\uB5A4 \uCE74\uB4DC\uB97C \uB098\uB220\uC904\uC9C0 \uC798 \uD310\uB2E8\uD558\uBA74,
    \uD310\uC744 \uC6D0\uD558\uB294 \uB300\uB85C \uB9CC\uB4E4 \uC218 \uC788\uC744
    \uAC70\uC57C.\r\n\uC11C\uD22C\uB974\uAC8C \uD589\uB3D9\uD558\uBA74 \uADF8\uB54C\uCC98\uB7FC
    \uC758\uC2EC\uC744 \uC0B4 \uD14C\uB2C8 \uC870\uC2EC\uD558\uACE0.\r\r"
  - "\uB9C8\uD53C\uC544: \uB124\uAC00 \uC0AC\uC6A9\uD560 \uCE74\uB4DC\uB294 \uB4B7\uBA74\uC5D0
    \uD45C\uC2DC\uAC00 \uB3FC \uC788\uC5B4. \uB4B7\uBA74\uB9CC \uBCF4\uACE0\uB3C4
    \uC55E\uBA74\uC744 \uC54C \uC218 \uC788\uC9C0.\r\n\uB610, \uC0AC\uB78C\uB4E4\uC774
    \uBCA0\uD305\uC744 \uD560 \uB54C, \uB9E8 \uBC11 \uC7A5\uC744 \uBAB0\uB798 \uD655\uC778\uD560
    \uC218 \uC788\uC5B4.\r\n\uC774 \uC815\uBCF4\uB4E4\uC744 \uAC00\uC9C0\uACE0 \uC798
    \uD310\uB2E8\uD574\uBD10.\r"
  - "\uB9C8\uD53C\uC544: \uC190\uB2D8\uC758 \uC2B9\uB9AC\uAC00 \uD655\uC2E4\uD560
    \uB550, W\uD0A4\uB97C \uB204\uB978 \uB4A4 \uC190\uB2D8\uC744 \uD074\uB9AD\uD574\uC11C
    \uC2E0\uD638\uB97C \uC904 \uC218 \uC788\uC5B4.\r\n\uC2E0\uD638\uB97C \uBC1B\uC740
    \uC190\uB2D8\uC740 \uB354 \uB192\uC740 \uBCA0\uD305\uC744 \uD560 \uAC70\uC57C.\r\n\uC2E0\uD638\uB97C
    \uC900 \uB4A4, \uB2E4\uC2DC \uCE74\uB4DC\uB97C \uB098\uB220\uC8FC\uB824\uBA74
    Q\uD0A4\uB97C \uB204\uB974\uBA74 \uB3FC.\r\r"
  - "\uB9C8\uD53C\uC544: \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uC6B0\uB9AC \uC190\uB2D8\uC740
    \uAF64 \uC131\uACA9\uC774 \uBD88\uAC19\uC544\uC11C \uB9D0\uC774\uC57C,\r\n\uB3C8\uC744
    \uCDA9\uBD84\uD788 \uBC8C\uC9C0 \uBABB\uD558\uBA74 \uBB34\uCC99\uC774\uB098 \uD654\uB97C
    \uB0B4\uC2E4 \uAC70\uC57C.\r\n\uADF8\uB807\uAC8C \uB418\uBA74 \uC6B0\uB9AC\uB3C4
    \uB110 \uBBFF\uACE0 \uC4F8 \uC218 \uC5C6\uC9C0. \uC5F4\uC2EC\uD788 \uD574\uBCF4\uB77C\uACE0.\r\r"
  - "\uB9C8\uD53C\uC544: \uACE7 \uAC8C\uC784\uC774 \uC2DC\uC791\uB418\uACA0\uAD70.
    \uC5BC\uB978 \uAC00 \uBD10."
  - "\uB9C8\uD53C\uC544: \uBB34\uC0AC\uD788 \uD558\uB8E8\uB97C \uC798 \uB118\uACBC\uAD70,
    \uD6CC\uB96D\uD574. \uC790\uB124\uB97C \u201C\uACE0\uC6A9\u201D\uD55C \uAC74
    \uC798 \uD55C \uC77C\uC778 \uAC83 \uAC19\uAD70.\r"
  - "\uB9C8\uD53C\uC544: \uC624\uB298\uBD80\uD130\uB294 \uC870\uAE08\uC740 \uBD88\uB7C9\uD55C
    \uB188\uB4E4\uC774 \uCC3E\uC544\uC62C \uAC70\uC57C. \uBAB0\uB798 \uCE74\uB4DC\uB97C
    \uBC14\uAFD4\uCCD0\uC11C \uAC8C\uC784\uC744 \uC870\uC791\uD558\uB824\uB294 \uB188\uB4E4\uC774\uC9C0.
    \uBC84\uB7EC\uC9C0 \uAC19\uC740 \uC0C8\uB07C\uB4E4\u2026\r"
  - "\uB9C8\uD53C\uC544: \uB9CC\uC57D \uADF8\uB7F0 \uB188\uB4E4\uC774 \uBCF4\uC778\uB2E4\uBA74,
    R\uD0A4\uB97C \uB204\uB974\uACE0 \uADF8 \uB188\uC744 \uD074\uB9AD\uD574\uC11C
    \uACE0\uBC1C\uD558\uB3C4\uB85D \uD574.\r\n\uC0AC\uAE30 \uD589\uAC01\uC744 \uBC14\uB85C
    \uC801\uBC1C\uD55C\uB2E4\uBA74, \uC6B0\uB9AC\uAC00 \uC9C1\uC811 \uCC98\uB9AC\uD558\uC9C0.\r\r\n\r"
  - "\uB9C8\uD53C\uC544: \uD558\uC9C0\uB9CC \uC870\uC2EC\uD574. \uC870\uAE08\uC774\uB77C\uB3C4
    \uB2A6\uC73C\uBA74, \uADF8 \uB188\uB4E4\uC740 \uC0AC\uAE30\uC758 \uD754\uC801\uC744
    \uB9D0\uB054\uD788 \uC5C6\uC560\uBC84\uB9B4 \uAC70\uC57C.\r\n\uADF8\uB807\uAC8C
    \uB418\uBA74 \uC6B0\uB9AC\uB3C4 \uADF8 \uB188\uB4E4\uC744 \uCC98\uB9AC\uD560
    \uC218 \uC5C6\uACE0, \uB108\uB3C4 \uCC45\uC784\uC744 \uD53C\uD560 \uC218 \uC5C6\uC744
    \uAC70\uC57C.\r\n\uC2E0\uC911\uD558\uAC8C \uD589\uB3D9\uD574.\r"
  - "\uB9C8\uD53C\uC544: \uACE7 \uAC8C\uC784\uC774 \uC2DC\uC791\uD558\uACA0\uAD70.
    \uC624\uB298\uB3C4 \uC190\uB2D8 \uB300\uC811 \uC798 \uD574\uBCF4\uAC8C."
  - "\uAC8C\uC784\uC774 \uB05D\uB098\uACE0 \uBAA8\uB4E0 \uD50C\uB808\uC774\uC5B4\uAC00
    \uB098\uAC04 \uB4A4, \uB2F9\uC2E0\uC740 \uB3C4\uBC15\uC7A5\uC5D0 \uD640\uB85C
    \uB0A8\uC544 \uD14C\uC774\uBE14\uC744 \uC815\uB9AC\uD55C\uB2E4.\r\n\uC815\uB9AC\uB97C
    \uB9C8\uCE5C \uB4A4 \uB2F9\uC2E0\uC740 \uB3C4\uBC15\uC7A5 \uADFC\uCC98\uC5D0
    \uB9C8\uB828\uB41C \uAC10\uC625 \uAC19\uC740 \uC219\uC18C\uB85C \uD5A5\uD55C\uB2E4.\r"
  - "\uBC29\uBB38\uC744 \uC5F4\uC790, \uD3B8\uC9C0 \uD55C \uC7A5\uC774 \uB2F9\uC2E0\uC744
    \uAE30\uB2E4\uB838\uB2E4\uB294 \uB4EF \uBB38 \uD2C8\uC5D0\uC11C \uB5A8\uC5B4\uC9C4\uB2E4.\r\n\uB2F9\uC2E0\uC740
    \uBC29\uC5D0 \uB4E4\uC5B4\uAC00 \uADF8 \uD3B8\uC9C0\uB97C \uC5F0\uB2E4."
  - "\uD3B8\uC9C0: \uB2F9\uC2E0\uC774 \uC77C\uD558\uACE0 \uC788\uB294 \uACF3\uC5D0
    \uB300\uD574 \uAC1C\uC778\uC801\uC73C\uB85C \uC870\uC0AC\uD558\uACE0 \uC788\uC2B5\uB2C8\uB2E4.\r\n\uD611\uC870\uD574\uC8FC\uC2E0\uB2E4\uBA74,
    \uADF8 \uB3C4\uBC15\uC7A5\uC5D0\uC11C \uD0C8\uCD9C\uD560 \uC218 \uC788\uAC8C
    \uB3C4\uC640\uB4DC\uB9AC\uC8E0.\r\n\uB0B4\uC77C \uBD59\uACA0\uC2B5\uB2C8\uB2E4.
    \uC81C\uAC00 \uB204\uAD6C\uC778\uC9C0\uB294, \uAE08\uBC29 \uC54C \uC218 \uC788\uC744
    \uAC81\uB2C8\uB2E4.\r\n"
  - "\uD3B8\uC9C0\uB97C \uC77D\uC740 \uB2F9\uC2E0\uC740 \uC0DD\uAC01\uB4E4\uB85C
    \uBA38\uB9AC\uAC00 \uBCF5\uC7A1\uD574\uC9C4\uB2E4. \r\n\uB3C4\uBC15, \uC0AC\uAE30,
    \uACC4\uC57D, \uC870\uC791, \uD3B8\uC9C0, \uD0C8\uCD9C\u2026\r\n\uB2E4\uC74C
    \uB0A0 \uC5B4\uB5A4 \uC77C\uC774 \uBC8C\uC5B4\uC9C8\uC9C0 \uAC00\uB2A0\uB3C4
    \uBABB\uD55C \uCC44\uB85C, \uB2F9\uC2E0\uC740 \uBC24\uC744 \uB9DE\uB294\uB2E4.
    \r"
  - "UNFOLDED DEMO\n\uD50C\uB808\uC774\uD574\uC8FC\uC154\uC11C \uAC10\uC0AC\uD569\uB2C8\uB2E4.\r"
